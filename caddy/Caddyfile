# ============================================
# IVS Caddy Reverse Proxy Configuration
# ============================================

# Dashboard (main entry point)
{$DOMAIN_SUFFIX:vibe.local} {
	reverse_proxy frontend:3000
}

# Backend API
api.{$DOMAIN_SUFFIX:vibe.local} {
	reverse_proxy backend:8000
}

# Gitea
git.{$DOMAIN_SUFFIX:vibe.local} {
	reverse_proxy gitea:3000
}

# Fallback: direct IP access
:80 {
	@api path /api/*
	handle @api {
		reverse_proxy backend:8000
	}

	@ws path /api/system/ws/*
	handle @ws {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
